/**
 * Database types for Supabase
 * Alce's Barbearia - White Label SaaS
 * 
 * Terminology: "Barber" is the standard term for professionals
 */

export type UserRole = 'owner' | 'manager' | 'leader' | 'barber' | 'super_admin';
export type BarberLevel = 'junior' | 'professional' | 'senior' | 'master';
export type ClientStatus = 'active' | 'inactive' | 'blacklist' | 'blacklisted' | 'overdue';
export type TransactionType = 'service' | 'product' | 'expense' | 'withdrawal' | 'deposit';
export type PaymentMethod = 'cash' | 'card' | 'pix';
export type CashRegisterStatus = 'open' | 'closed';
export type CommissionStatus = 'pending' | 'paid';
export type GoalType = 'revenue' | 'services' | 'products';
export type GoalPeriod = 'daily' | 'weekly' | 'monthly';
export type MembershipRole = 'owner' | 'manager' | 'leader' | 'barber';
export type SubscriptionStatus = 'trialing' | 'active' | 'past_due' | 'canceled';
export type BillingInterval = 'monthly' | 'yearly';
export type InvoiceStatus = 'pending' | 'paid' | 'overdue' | 'canceled';
export type BillingEventStatus = 'received' | 'processed' | 'failed';
export type AppointmentStatus = 'scheduled' | 'confirmed' | 'checked_in' | 'completed' | 'canceled' | 'no_show';
export type AppointmentSource = 'admin' | 'client';
export type CampaignChannel = 'whatsapp' | 'sms' | 'email' | 'manual';
export type CampaignStatus = 'draft' | 'active' | 'paused' | 'completed';
export type CampaignResultStatus = 'delivered' | 'opened' | 'converted' | 'failed';
export type CashbackTriggerType = 'service_purchase' | 'on_time_arrival' | 'plan_renewal' | 'manual';
export type CashbackAmountType = 'fixed' | 'percentage';
export type CashbackMovementType = 'credit' | 'debit' | 'expire' | 'adjustment';

export type Profile = {
    id: string;
    full_name: string;
    avatar_url: string | null;
    role: UserRole;
    created_at: string;
    updated_at: string;
}

export type Store = {
    id: string;
    name: string;
    phone?: string | null;
    address: string | null;
    open_time: string;
    close_time: string;
    created_at: string;
    updated_at: string;
}

export type Settings = {
    id: string;
    store_id: string;
    logo_url: string | null;
    primary_color: string;
    secondary_color: string;
    background_color: string;
    card_color: string;
    font_family: string;
    border_radius: string;
    spacing: string;
    theme: string;
    custom_domain: string | null;
    commission_percentage: number;
    created_at: string;
    updated_at: string;
}

export type Barber = {
    id: string;
    profile_id: string | null;
    store_id: string;
    name: string;
    initials: string | null;
    phone?: string | null;
    email?: string | null;
    hire_date: string | null;
    level: BarberLevel;
    level_multiplier: number;
    is_leader: boolean;
    is_active: boolean;
    created_at: string;
    updated_at: string;
}

export type Service = {
    id: string;
    store_id: string;
    name: string;
    description: string | null;
    price: number;
    duration_minutes: number;
    points: number;
    category?: string | null;
    is_active: boolean;
    created_at: string;
}

export type Product = {
    id: string;
    store_id: string;
    name: string;
    description: string | null;
    price: number;
    cost: number | null;
    stock_quantity: number;
    min_stock: number;
    category?: string | null;
    sku?: string | null;
    is_active: boolean;
    created_at: string;
}

export type Client = {
    id: string;
    store_id: string;
    name: string;
    phone?: string | null;
    email?: string | null;
    notes: string | null;
    status: ClientStatus;
    preferred_barber_id: string | null;
    total_visits: number;
    last_visit_at: string | null;
    created_at: string;
}

export type CashRegister = {
    id: string;
    store_id: string;
    opened_by: string | null;
    closed_by: string | null;
    opened_at: string;
    closed_at: string | null;
    opening_balance: number;
    closing_balance: number | null;
    status: CashRegisterStatus;
}

export type Transaction = {
    id: string;
    store_id: string;
    cash_register_id: string | null;
    barber_id: string | null;
    client_id: string | null;
    type: TransactionType;
    description: string | null;
    amount: number;
    payment_method: PaymentMethod | null;
    created_at: string;
}

export type TransactionItem = {
    id: string;
    transaction_id: string;
    service_id: string | null;
    product_id: string | null;
    quantity: number;
    unit_price: number;
    points: number;
}

export type Points = {
    id: string;
    store_id: string;
    barber_id: string;
    transaction_id: string;
    points: number;
    earned_at: string;
}

export type Commission = {
    id: string;
    store_id: string;
    barber_id: string;
    period_start: string;
    period_end: string;
    total_points: number;
    base_value: number;
    multiplier: number;
    final_value: number;
    status: CommissionStatus;
    paid_at: string | null;
    created_at: string;
}

export type Expense = {
    id: string;
    store_id: string;
    cash_register_id: string | null;
    category: string;
    description: string | null;
    amount: number;
    expense_date: string;
    created_by: string | null;
    created_at: string;
}

export type Goal = {
    id: string;
    store_id: string;
    barber_id: string;
    type: GoalType;
    target_value: number;
    current_value: number;
    period: GoalPeriod;
    start_date: string;
    end_date: string;
    is_achieved: boolean;
    created_at: string;
}

export type Schedule = {
    id: string;
    store_id: string;
    barber_id: string;
    day_of_week: number; // 0-6 (Sunday-Saturday)
    start_time: string;
    end_time: string;
    is_active: boolean;
}

export type CareerLevel = {
    id: string;
    store_id: string;
    name: string;
    level_order: number;
    multiplier: number;
    min_months: number;
    min_services: number;
    min_rating: number;
    benefits: string | null;
    created_at: string;
}

export type UserStoreMembership = {
    id: string;
    user_id: string;
    store_id: string;
    role: MembershipRole;
    is_active: boolean;
    created_at: string;
    updated_at: string;
}

export type SubscriptionPlan = {
    id: string;
    code: string;
    name: string;
    billing_interval: BillingInterval;
    amount_cents: number;
    trial_days: number;
    is_active: boolean;
    created_at: string;
    updated_at: string;
}

export type StoreSubscription = {
    id: string;
    store_id: string;
    plan_id: string | null;
    provider: 'asaas';
    provider_customer_id: string | null;
    provider_subscription_id: string | null;
    status: SubscriptionStatus;
    current_period_start: string | null;
    current_period_end: string | null;
    canceled_at: string | null;
    metadata: Record<string, unknown>;
    created_at: string;
    updated_at: string;
}

export type SubscriptionInvoice = {
    id: string;
    subscription_id: string;
    store_id: string;
    provider_invoice_id: string | null;
    status: InvoiceStatus;
    amount_cents: number;
    due_date: string | null;
    paid_at: string | null;
    raw_payload: Record<string, unknown>;
    created_at: string;
    updated_at: string;
}

export type BillingEvent = {
    id: string;
    store_id: string | null;
    provider: 'asaas';
    event_id: string;
    event_type: string;
    status: BillingEventStatus;
    payload: Record<string, unknown>;
    error_message: string | null;
    processed_at: string | null;
    created_at: string;
}

export type Appointment = {
    id: string;
    store_id: string;
    client_id: string | null;
    barber_id: string | null;
    starts_at: string;
    ends_at: string;
    status: AppointmentStatus;
    notes: string | null;
    source: AppointmentSource;
    created_by: string | null;
    created_at: string;
    updated_at: string;
}

export type AppointmentService = {
    id: string;
    appointment_id: string;
    service_id: string | null;
    quantity: number;
    unit_price: number;
    points: number;
    created_at: string;
}

export type CashRegisterEvent = {
    id: string;
    store_id: string;
    cash_register_id: string;
    event_type: 'opened' | 'entry' | 'withdrawal' | 'expense' | 'closed';
    amount: number;
    description: string | null;
    created_by: string | null;
    created_at: string;
}

export type ClientVisitHistory = {
    id: string;
    store_id: string;
    client_id: string;
    transaction_id: string;
    barber_id: string | null;
    amount: number;
    occurred_at: string;
}

export type ClientSegment = {
    id: string;
    store_id: string;
    name: string;
    filters: Record<string, unknown>;
    is_active: boolean;
    created_at: string;
    updated_at: string;
}

export type Campaign = {
    id: string;
    store_id: string;
    segment_id: string | null;
    name: string;
    objective: string;
    channel: CampaignChannel;
    status: CampaignStatus;
    starts_at: string | null;
    ends_at: string | null;
    created_by: string | null;
    created_at: string;
    updated_at: string;
}

export type CampaignResult = {
    id: string;
    campaign_id: string;
    store_id: string;
    client_id: string | null;
    status: CampaignResultStatus;
    revenue_amount: number;
    recorded_at: string;
    metadata: Record<string, unknown>;
}

export type CashbackRule = {
    id: string;
    store_id: string;
    name: string;
    trigger_type: CashbackTriggerType;
    amount_type: CashbackAmountType;
    amount_value: number;
    min_amount: number;
    is_active: boolean;
    created_at: string;
    updated_at: string;
}

export type CashbackLedgerEntry = {
    id: string;
    store_id: string;
    client_id: string;
    transaction_id: string | null;
    appointment_id: string | null;
    rule_id: string | null;
    movement_type: CashbackMovementType;
    amount: number;
    description: string | null;
    metadata: Record<string, unknown>;
    created_by: string | null;
    created_at: string;
}

// Supabase Database type for client
export type Database = {
    public: {
        Tables: {
            profiles: {
                Row: Profile;
                Insert: Omit<Profile, 'created_at' | 'updated_at'>;
                Update: Partial<Omit<Profile, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            stores: {
                Row: Store;
                Insert: Omit<Store, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<Store, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            settings: {
                Row: Settings;
                Insert: Omit<Settings, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<Settings, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            barbers: {
                Row: Barber;
                Insert: Omit<Barber, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<Barber, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            services: {
                Row: Service;
                Insert: Omit<Service, 'id' | 'created_at'>;
                Update: Partial<Omit<Service, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            products: {
                Row: Product;
                Insert: Omit<Product, 'id' | 'created_at'>;
                Update: Partial<Omit<Product, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            clients: {
                Row: Client;
                Insert: 'created_at'|'created_at';
                Update: Partial<'created_at'|'created_at'>;
                Relationships: any[];
            };
            cash_registers: {
                Row: CashRegister;
                Insert: Partial<CashRegister> & Pick<CashRegister, 'store_id' | 'opening_balance' | 'opened_by' | 'status'>;
                Update: Partial<Omit<CashRegister, 'id' | 'opened_at'>>;
                Relationships: any[];
            };
            transactions: {
                Row: Transaction;
                Insert: Omit<Transaction, 'id' | 'created_at'>;
                Update: Partial<Omit<Transaction, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            transaction_items: {
                Row: TransactionItem;
                Insert: Omit<TransactionItem, 'id'>;
                Update: Partial<Omit<TransactionItem, 'id'>>;
                Relationships: any[];
            };
            points: {
                Row: Points;
                Insert: Omit<Points, 'id' | 'earned_at'>;
                Update: Partial<Omit<Points, 'id'>>;
                Relationships: any[];
            };
            commissions: {
                Row: Commission;
                Insert: 'created_at'|'created_at';
                Update: Partial<'created_at'|'created_at'>;
                Relationships: any[];
            };
            expenses: {
                Row: Expense;
                Insert: Omit<Expense, 'id' | 'created_at'>;
                Update: Partial<Omit<Expense, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            goals: {
                Row: Goal;
                Insert: Omit<Goal, 'id' | 'created_at'>;
                Update: Partial<Omit<Goal, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            schedules: {
                Row: Schedule;
                Insert: Omit<Schedule, 'id'>;
                Update: Partial<Omit<Schedule, 'id'>>;
                Relationships: any[];
            };
            career_levels: {
                Row: CareerLevel;
                Insert: Omit<CareerLevel, 'id' | 'created_at'>;
                Update: Partial<Omit<CareerLevel, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            user_store_memberships: {
                Row: UserStoreMembership;
                Insert: Omit<UserStoreMembership, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<UserStoreMembership, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            subscription_plans: {
                Row: SubscriptionPlan;
                Insert: Omit<SubscriptionPlan, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<SubscriptionPlan, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            store_subscriptions: {
                Row: StoreSubscription;
                Insert: Omit<StoreSubscription, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<StoreSubscription, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            subscription_invoices: {
                Row: SubscriptionInvoice;
                Insert: Omit<SubscriptionInvoice, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<SubscriptionInvoice, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            billing_events: {
                Row: BillingEvent;
                Insert: Omit<BillingEvent, 'id' | 'created_at'>;
                Update: Partial<Omit<BillingEvent, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            appointments: {
                Row: Appointment;
                Insert: Omit<Appointment, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<Appointment, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            appointment_services: {
                Row: AppointmentService;
                Insert: Omit<AppointmentService, 'id' | 'created_at'>;
                Update: Partial<Omit<AppointmentService, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            cash_register_events: {
                Row: CashRegisterEvent;
                Insert: Omit<CashRegisterEvent, 'id' | 'created_at'>;
                Update: Partial<Omit<CashRegisterEvent, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            client_visit_history: {
                Row: ClientVisitHistory;
                Insert: Omit<ClientVisitHistory, 'id'>;
                Update: Partial<Omit<ClientVisitHistory, 'id'>>;
                Relationships: any[];
            };
            client_segments: {
                Row: ClientSegment;
                Insert: Omit<ClientSegment, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<ClientSegment, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            campaigns: {
                Row: Campaign;
                Insert: Omit<Campaign, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<Campaign, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            campaign_results: {
                Row: CampaignResult;
                Insert: Omit<CampaignResult, 'id'>;
                Update: Partial<Omit<CampaignResult, 'id'>>;
                Relationships: any[];
            };
            cashback_rules: {
                Row: CashbackRule;
                Insert: Omit<CashbackRule, 'id' | 'created_at' | 'updated_at'>;
                Update: Partial<Omit<CashbackRule, 'id' | 'created_at'>>;
                Relationships: any[];
            };
            cashback_ledger: {
                Row: CashbackLedgerEntry;
                Insert: Omit<CashbackLedgerEntry, 'id' | 'created_at'>;
                Update: Partial<Omit<CashbackLedgerEntry, 'id' | 'created_at'>>;
                Relationships: any[];
            };
        };
        Views: { [_ in never]: never };
        Functions: { [_ in never]: never };
        Enums: { [_ in never]: never };
        CompositeTypes: { [_ in never]: never };
    };
}

// Helper type to get table row type
export type TableRow<T extends keyof Database['public']['Tables']> =
    Database['public']['Tables'][T]['Row'];
